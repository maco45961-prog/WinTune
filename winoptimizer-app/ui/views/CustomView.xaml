<UserControl x:Class="WinOptimizer.UI.CustomView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <Grid Margin="40,32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="{StaticResource CustomTitle}" FontSize="28" FontWeight="Bold"
                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>

        <!-- Search + Actions -->
        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource BgCardBrush}" CornerRadius="8"
                    Padding="12,6" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="0,0,12,0">
                <Grid>
                    <TextBlock Text="{StaticResource SearchPlaceholder}" Foreground="{StaticResource TextMutedBrush}"
                               VerticalAlignment="Center" FontSize="13" x:Name="SearchPlaceholder"
                               IsHitTestVisible="False" Visibility="Visible"/>
                    <TextBox x:Name="SearchBox" Background="Transparent" BorderThickness="0"
                             Foreground="{StaticResource TextPrimaryBrush}" FontSize="13"
                             VerticalContentAlignment="Center"
                             TextChanged="SearchBox_TextChanged"/>
                </Grid>
            </Border>

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="{StaticResource SelectAll}" Style="{StaticResource LinkButtonStyle}"
                        Click="SelectAll_Click" Margin="0,0,12,0"/>
                <Button Content="{StaticResource DeselectAll}" Style="{StaticResource LinkButtonStyle}"
                        Click="DeselectAll_Click" Margin="0,0,12,0"/>
                <TextBlock x:Name="SelectedCountText" Text="0 seleccionados" FontSize="13"
                           Foreground="{StaticResource AccentPrimaryBrush}" VerticalAlignment="Center" FontWeight="SemiBold"/>
            </StackPanel>
        </Grid>

        <!-- Tweak List -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="TweaksPanel"/>
        </ScrollViewer>

        <!-- Apply Button -->
        <Border Grid.Row="3" Background="{StaticResource BgSecondaryBrush}" Padding="0,16,0,0"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Margin="0,16,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="ApplyBtn" Content="{StaticResource ApplySelection}"
                        Style="{StaticResource ApplyButtonStyle}" Click="Apply_Click"
                        IsEnabled="False"/>
            </StackPanel>
        </Border>
    </Grid>

    <UserControl.Resources>
        <Style x:Key="LinkButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource AccentPrimaryBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style x:Key="ApplyButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentPrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="28,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="8"
                                Padding="{TemplateBinding Padding}" Opacity="{TemplateBinding IsEnabled, Converter={x:Static local:OpacityConverter.Instance}}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
</UserControl>

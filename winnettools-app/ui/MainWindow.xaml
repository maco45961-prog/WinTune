<Window x:Class="WinNetTools.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{StaticResource AppTitle}"
        Width="1100" Height="750"
        MinWidth="800" MinHeight="600"
        Background="{StaticResource BgPrimaryBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{StaticResource BgSecondaryBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
            <StackPanel Margin="12">
                <TextBlock Text="{StaticResource AppTitle}" FontSize="16" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" Margin="0,8,0,24" TextWrapping="Wrap"/>

                <Button Content="{StaticResource Dashboard}" Click="NavDashboard" Style="{StaticResource SecondaryButton}" Margin="0,0,0,4" HorizontalContentAlignment="Left"/>
                <Button Content="{StaticResource Traceroute}" Click="NavTraceroute" Style="{StaticResource SecondaryButton}" Margin="0,0,0,4" HorizontalContentAlignment="Left"/>
                <Button Content="{StaticResource DNS}" Click="NavDns" Style="{StaticResource SecondaryButton}" Margin="0,0,0,4" HorizontalContentAlignment="Left"/>
                <Button Content="{StaticResource Processes}" Click="NavProcesses" Style="{StaticResource SecondaryButton}" Margin="0,0,0,4" HorizontalContentAlignment="Left"/>
                <Button Content="{StaticResource Report}" Click="NavReport" Style="{StaticResource SecondaryButton}" Margin="0,0,0,4" HorizontalContentAlignment="Left"/>

                <Button Content="EN / ES" Click="ToggleLanguage" Style="{StaticResource SecondaryButton}" Margin="0,24,0,0" HorizontalContentAlignment="Left" FontSize="12"/>
            </StackPanel>
        </Border>

        <!-- Content area -->
        <Border Grid.Column="1" Background="{StaticResource BgPrimaryBrush}">
            <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden"/>
        </Border>
    </Grid>
</Window>

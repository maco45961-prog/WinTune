<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Dark theme palette -->
    <Color x:Key="BgPrimary">#1E1E1E</Color>
    <Color x:Key="BgSecondary">#2D2D2D</Color>
    <Color x:Key="BgTertiary">#383838</Color>
    <Color x:Key="BgCard">#252526</Color>
    <Color x:Key="TextPrimary">#E0E0E0</Color>
    <Color x:Key="TextSecondary">#9E9E9E</Color>
    <Color x:Key="TextMuted">#6E6E6E</Color>
    <Color x:Key="Accent">#0D98E8</Color>
    <Color x:Key="AccentHover">#1AA8F0</Color>
    <Color x:Key="Success">#4CAF50</Color>
    <Color x:Key="Warning">#FF9800</Color>
    <Color x:Key="Danger">#F44336</Color>
    <Color x:Key="Border">#3E3E3E</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="BgPrimaryBrush" Color="{StaticResource BgPrimary}"/>
    <SolidColorBrush x:Key="BgSecondaryBrush" Color="{StaticResource BgSecondary}"/>
    <SolidColorBrush x:Key="BgTertiaryBrush" Color="{StaticResource BgTertiary}"/>
    <SolidColorBrush x:Key="BgCardBrush" Color="{StaticResource BgCard}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMuted}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource Accent}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource Success}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource Warning}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource Danger}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource Border}"/>

    <!-- i18n strings (English default) -->
    <s:String x:Key="AppTitle">WinNetTools — Network Diagnostics</s:String>
    <s:String x:Key="Dashboard">Dashboard</s:String>
    <s:String x:Key="Traceroute">Traceroute</s:String>
    <s:String x:Key="DNS">DNS Compare</s:String>
    <s:String x:Key="Processes">Network Processes</s:String>
    <s:String x:Key="Report">Export Report</s:String>
    <s:String x:Key="PingLatency">Ping / Jitter / Packet Loss</s:String>
    <s:String x:Key="ConnectionType">Connection Type</s:String>
    <s:String x:Key="NetworkHealth">Network Health</s:String>
    <s:String x:Key="Good">Good</s:String>
    <s:String x:Key="Fair">Fair</s:String>
    <s:String x:Key="Poor">Poor</s:String>
    <s:String x:Key="Critical">Critical</s:String>
    <s:String x:Key="Target">Target</s:String>
    <s:String x:Key="Avg">Avg</s:String>
    <s:String x:Key="Min">Min</s:String>
    <s:String x:Key="Max">Max</s:String>
    <s:String x:Key="Jitter">Jitter</s:String>
    <s:String x:Key="Loss">Loss</s:String>
    <s:String x:Key="Hop">Hop</s:String>
    <s:String x:Key="Address">Address</s:String>
    <s:String x:Key="Latency">Latency</s:String>
    <s:String x:Key="RunTest">Run Test</s:String>
    <s:String x:Key="RunTraceroute">Run Traceroute</s:String>
    <s:String x:Key="ResolveDNS">Resolve DNS</s:String>
    <s:String x:Key="CompareDNS">Compare DNS Servers</s:String>
    <s:String x:Key="RefreshProcesses">Refresh Processes</s:String>
    <s:String x:Key="GenerateReport">Generate Report</s:String>
    <s:String x:Key="ReportSaved">Report saved to:</s:String>
    <s:String x:Key="WiFiWarning">Wi-Fi introduces variable jitter that no software tweak can fully fix. Consider using a wired connection.</s:String>
    <s:String x:Key="NagleSuggestion">Nagle algorithm is active — consider disabling it via WinOptimizer for lower latency.</s:String>
    <s:String x:Key="DnsSuggestion">Your current DNS is slower than alternatives — consider switching via WinOptimizer.</s:String>
    <s:String x:Key="DeliveryOptimizationWarning">Delivery Optimization (P2P Windows Update) is active and may consume bandwidth.</s:String>
    <s:String x:Key="OpenOptimizer">Open in Optimizer</s:String>

    <Style TargetType="Button" x:Key="PrimaryButton">
        <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Padding" Value="12,6"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="Button" x:Key="SecondaryButton">
        <Setter Property="Background" Value="{StaticResource BgTertiaryBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="Padding" Value="12,6"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="StatusGreen" TargetType="Border">
        <Setter Property="Background" Value="#2E7D32"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Padding" Value="8,4"/>
    </Style>
    <Style x:Key="StatusYellow" TargetType="Border">
        <Setter Property="Background" Value="#F57F17"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Padding" Value="8,4"/>
    </Style>
    <Style x:Key="StatusRed" TargetType="Border">
        <Setter Property="Background" Value="#C62828"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Padding" Value="8,4"/>
    </Style>

    <Style TargetType="ListViewItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListViewItem">
                    <Border Background="{TemplateBinding Background}" BorderThickness="0" Padding="4">
                        <ContentPresenter/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>

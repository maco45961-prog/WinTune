<Page x:Class="WinBenchmark.UI.Views.HistoryView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BgPrimaryBrush}"
      Foreground="{StaticResource TextPrimaryBrush}">
    <StackPanel Margin="24">
        <TextBlock Text="{StaticResource History}" FontSize="22" FontWeight="Bold" Margin="0,0,0,16"/>

        <Border Background="{StaticResource BgCardBrush}" CornerRadius="8" Padding="0">
            <ListView x:Name="HistoryList" Background="Transparent" BorderThickness="0">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Fecha" Width="140" DisplayMemberBinding="{Binding StartTime}"/>
                        <GridViewColumn Header="{StaticResource AvgFps}" Width="80" DisplayMemberBinding="{Binding AvgFps}"/>
                        <GridViewColumn Header="{StaticResource Low1Percent}" Width="80" DisplayMemberBinding="{Binding Low1PercentFps}"/>
                        <GridViewColumn Header="{StaticResource Low01Percent}" Width="80" DisplayMemberBinding="{Binding Low01PercentFps}"/>
                        <GridViewColumn Header="{StaticResource FrameTimeMs}" Width="90" DisplayMemberBinding="{Binding AvgFrameTimeMs}"/>
                        <GridViewColumn Header="{StaticResource CpuUsage}" Width="70" DisplayMemberBinding="{Binding AvgCpuPercent}"/>
                        <GridViewColumn Header="{StaticResource RamUsage}" Width="80" DisplayMemberBinding="{Binding AvgRamGb}"/>
                        <GridViewColumn Header="{StaticResource PingMs}" Width="70" DisplayMemberBinding="{Binding AvgPingMs}"/>
                        <GridViewColumn Header="{StaticResource JitterMs}" Width="70" DisplayMemberBinding="{Binding AvgJitterMs}"/>
                        <GridViewColumn Header="Perfil" Width="140" DisplayMemberBinding="{Binding SystemState.ProfileApplied}"/>
                        <GridViewColumn Header="Duración" Width="70" DisplayMemberBinding="{Binding DurationSeconds}"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </Border>

        <TextBlock x:Name="EmptyText" Text="{StaticResource NoSessions}" Foreground="{StaticResource TextMutedBrush}" Margin="0,12,0,0" Visibility="Collapsed"/>

        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
            <Button Content="{StaticResource GenerateReport}" Style="{StaticResource SecondaryButton}" Click="ExportAll"/>
        </StackPanel>
        <TextBlock x:Name="ExportStatus" Foreground="{StaticResource SuccessBrush}" Margin="0,8,0,0" Visibility="Collapsed"/>
    </StackPanel>
</Page>

<Page x:Class="WinBenchmark.UI.Views.DashboardView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BgPrimaryBrush}"
      Foreground="{StaticResource TextPrimaryBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">
            <TextBlock Text="{StaticResource Dashboard}" FontSize="22" FontWeight="Bold" Margin="0,0,0,16"/>

            <!-- Welcome + stats summary -->
            <Border Background="{StaticResource BgCardBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock x:Name="TotalSessionsText" FontSize="16" FontWeight="SemiBold" Text="Cargando..." Margin="0,0,0,8"/>
                    <TextBlock x:Name="LatestSessionText" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- Quick action -->
            <Border Background="{StaticResource BgCardBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock FontSize="16" FontWeight="SemiBold" Text="{StaticResource StartBenchmark}" Margin="0,0,0,12"/>
                    <Button Content="{StaticResource StartBenchmark}" Style="{StaticResource PrimaryButton}" Click="GoToActiveSession" HorizontalAlignment="Left" Padding="24,10"/>
                </StackPanel>
            </Border>

            <!-- Recent sessions list -->
            <TextBlock FontSize="16" FontWeight="SemiBold" Text="{StaticResource History}" Margin="0,0,0,8"/>
            <Border Background="{StaticResource BgCardBrush}" CornerRadius="8" Padding="0">
                <ListView x:Name="RecentSessionsList" Background="Transparent" BorderThickness="0">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="{StaticResource AvgFps}" Width="90" DisplayMemberBinding="{Binding AvgFps}"/>
                            <GridViewColumn Header="{StaticResource Low1Percent}" Width="90" DisplayMemberBinding="{Binding Low1PercentFps}"/>
                            <GridViewColumn Header="{StaticResource FrameTimeMs}" Width="100" DisplayMemberBinding="{Binding AvgFrameTimeMs}"/>
                            <GridViewColumn Header="{StaticResource CpuUsage}" Width="80" DisplayMemberBinding="{Binding AvgCpuPercent}"/>
                            <GridViewColumn Header="{StaticResource RamUsage}" Width="80" DisplayMemberBinding="{Binding AvgRamGb}"/>
                            <GridViewColumn Header="{StaticResource PingMs}" Width="80" DisplayMemberBinding="{Binding AvgPingMs}"/>
                            <GridViewColumn Header="{StaticResource JitterMs}" Width="80" DisplayMemberBinding="{Binding AvgJitterMs}"/>
                            <GridViewColumn Header="Perfil" Width="140" DisplayMemberBinding="{Binding SystemState.ProfileApplied}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Border>
            <TextBlock x:Name="EmptyText" Text="{StaticResource NoSessions}" Foreground="{StaticResource TextMutedBrush}" Margin="0,12,0,0" Visibility="Collapsed"/>
        </StackPanel>
    </ScrollViewer>
</Page>

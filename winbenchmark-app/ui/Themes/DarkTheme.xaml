<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Dark theme palette -->
    <Color x:Key="BgPrimary">#1E1E1E</Color>
    <Color x:Key="BgSecondary">#2D2D2D</Color>
    <Color x:Key="BgTertiary">#383838</Color>
    <Color x:Key="BgCard">#252526</Color>
    <Color x:Key="TextPrimary">#E0E0E0</Color>
    <Color x:Key="TextSecondary">#9E9E9E</Color>
    <Color x:Key="TextMuted">#6E6E6E</Color>
    <Color x:Key="Accent">#0D98E8</Color>
    <Color x:Key="AccentHover">#1AA8F0</Color>
    <Color x:Key="Success">#4CAF50</Color>
    <Color x:Key="Warning">#FF9800</Color>
    <Color x:Key="Danger">#F44336</Color>
    <Color x:Key="Border">#3E3E3E</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="BgPrimaryBrush" Color="{StaticResource BgPrimary}"/>
    <SolidColorBrush x:Key="BgSecondaryBrush" Color="{StaticResource BgSecondary}"/>
    <SolidColorBrush x:Key="BgTertiaryBrush" Color="{StaticResource BgTertiary}"/>
    <SolidColorBrush x:Key="BgCardBrush" Color="{StaticResource BgCard}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMuted}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource Accent}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource Success}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource Warning}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource Danger}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource Border}"/>

    <s:String x:Key="AppTitle">WinBenchmark — Rendimiento</s:String>
    <s:String x:Key="Dashboard">Panel</s:String>
    <s:String x:Key="ActiveSession">Sesión Activa</s:String>
    <s:String x:Key="Compare">Comparar</s:String>
    <s:String x:Key="History">Historial</s:String>
    <s:String x:Key="StartBenchmark">Iniciar Benchmark</s:String>
    <s:String x:Key="StopBenchmark">Detener</s:String>
    <s:String x:Key="DurationSeconds">Duración (segundos)</s:String>
    <s:String x:Key="TargetProcess">Proceso a capturar (ej. VALORANT)</s:String>
    <s:String x:Key="NoSessions">No hay sesiones aún. ¡Haz clic en "Sesión Activa" para empezar!</s:String>
    <s:String x:Key="Before">Antes</s:String>
    <s:String x:Key="After">Después</s:String>
    <s:String x:Key="Delta">Delta</s:String>
    <s:String x:Key="SelectTwoSessions">Selecciona dos sesiones para comparar</s:String>
    <s:String x:Key="AvgFps">FPS Prom</s:String>
    <s:String x:Key="Low1Percent">1% Low</s:String>
    <s:String x:Key="Low01Percent">0.1% Low</s:String>
    <s:String x:Key="FrameTimeMs">Frame Time (ms)</s:String>
    <s:String x:Key="CpuUsage">CPU</s:String>
    <s:String x:Key="RamUsage">RAM</s:String>
    <s:String x:Key="PingMs">Ping (ms)</s:String>
    <s:String x:Key="JitterMs">Jitter (ms)</s:String>
    <s:String x:Key="GenerateReport">Exportar como JSON</s:String>
    <s:String x:Key="ReportSaved">Reporte guardado en:</s:String>

    <Style TargetType="Button" x:Key="PrimaryButton">
        <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Padding" Value="12,6"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="Button" x:Key="DangerButton">
        <Setter Property="Background" Value="{StaticResource DangerBrush}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Padding" Value="12,6"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="Button" x:Key="SecondaryButton">
        <Setter Property="Background" Value="{StaticResource BgTertiaryBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="Padding" Value="12,6"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ListViewItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListViewItem">
                    <Border Background="{TemplateBinding Background}" BorderThickness="0" Padding="4">
                        <ContentPresenter/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>

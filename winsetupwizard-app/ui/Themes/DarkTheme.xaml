<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Color x:Key="BgPrimary">#1E1E1E</Color>
    <Color x:Key="BgSecondary">#2D2D2D</Color>
    <Color x:Key="BgTertiary">#383838</Color>
    <Color x:Key="BgCard">#252526</Color>
    <Color x:Key="TextPrimary">#E0E0E0</Color>
    <Color x:Key="TextSecondary">#9E9E9E</Color>
    <Color x:Key="TextMuted">#6E6E6E</Color>
    <Color x:Key="Accent">#0D98E8</Color>
    <Color x:Key="Success">#4CAF50</Color>
    <Color x:Key="Warning">#FF9800</Color>
    <Color x:Key="Danger">#F44336</Color>
    <Color x:Key="Border">#3E3E3E</Color>

    <SolidColorBrush x:Key="BgPrimaryBrush" Color="{StaticResource BgPrimary}"/>
    <SolidColorBrush x:Key="BgSecondaryBrush" Color="{StaticResource BgSecondary}"/>
    <SolidColorBrush x:Key="BgTertiaryBrush" Color="{StaticResource BgTertiary}"/>
    <SolidColorBrush x:Key="BgCardBrush" Color="{StaticResource BgCard}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMuted}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource Accent}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource Success}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource Warning}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource Danger}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource Border}"/>

    <s:String x:Key="AppTitle">WinSetupWizard — Asistente de Configuración</s:String>
    <s:String x:Key="Step">Paso</s:String>
    <s:String x:Key="Of">de</s:String>
    <s:String x:Key="Back">Atrás</s:String>
    <s:String x:Key="Next">Siguiente</s:String>
    <s:String x:Key="Cancel">Cancelar</s:String>
    <s:String x:Key="Finish">Finalizar</s:String>
    <s:String x:Key="WelcomeTitle">¡Bienvenido a WinSetupWizard!</s:String>
    <s:String x:Key="WelcomeDesc">Este asistente te guiará paso a paso para dejar tu PC recién formateado listo para jugar en menos de 15 minutos. Detectaremos tu hardware, aplicaremos la configuración óptima, instalaremos drivers y apps esenciales.</s:String>
    <s:String x:Key="HardwareDetected">Hardware Detectado</s:String>
    <s:String x:Key="RecommendedProfile">Perfil Recomendado</s:String>
    <s:String x:Key="SelectProfile">Selecciona tu Perfil</s:String>
    <s:String x:Key="ProfileDesc">Elige qué nivel de optimización quieres aplicar a tu sistema</s:String>
    <s:String x:Key="DriverInstall">Instalación de Drivers</s:String>
    <s:String x:Key="DriverDesc">Descarga los drivers oficiales para tu hardware desde las páginas de los fabricantes. No descargamos nada automáticamente — revisa los enlaces y decide.</s:String>
    <s:String x:Key="AppInstall">Instalación de Apps</s:String>
    <s:String x:Key="AppDesc">Selecciona las apps que quieres instalar automáticamente via winget</s:String>
    <s:String x:Key="ApplyProfileStep">Aplicando Optimización</s:String>
    <s:String x:Key="ApplyProfileDesc">Vamos a aplicar el perfil seleccionado usando el Core Engine de WinOptimizer. Se creará un punto de restauración automáticamente.</s:String>
    <s:String x:Key="Summary">Resumen Final</s:String>
    <s:String x:Key="SummaryDesc">Esto es lo que se hizo en esta sesión</s:String>
    <s:String x:Key="Cpu">CPU</s:String>
    <s:String x:Key="Gpu">GPU</s:String>
    <s:String x:Key="Ram">RAM</s:String>
    <s:String x:Key="Disk">Disco</s:String>
    <s:String x:Key="Chassis">Tipo</s:String>
    <s:String x:Key="Desktop">PC Escritorio</s:String>
    <s:String x:Key="Laptop">Laptop</s:String>
    <s:String x:Key="Download">Abrir página de descarga</s:String>
    <s:String x:Key="InstallApps">Instalar Apps Seleccionadas</s:String>
    <s:String x:Key="ApplyNow">Aplicar Perfil Ahora</s:String>
    <s:String x:Key="WingetNotAvailable">⚠️ winget no está disponible en este sistema. Las apps no se podrán instalar automáticamente.</s:String>
    <s:String x:Key="RestartNeeded">⚠️ Este perfil requiere reinicio para que algunos cambios surtan efecto.</s:String>
    <s:String x:Key="OpenOptimizer">Abrir WinOptimizer para ajustes finos</s:String>
    <s:String x:Key="WhatWasDone">Qué se hizo</s:String>
    <s:String x:Key="WhatToDoNext">Qué falta hacer manualmente</s:String>

    <Style TargetType="Button" x:Key="PrimaryButton">
        <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Padding" Value="20,10"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="Button" x:Key="SecondaryButton">
        <Setter Property="Background" Value="{StaticResource BgTertiaryBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="Padding" Value="20,10"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ListViewItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
    </Style>

</ResourceDictionary>

<Window x:Class="WinSetupWizard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{StaticResource AppTitle}"
        Width="900" Height="650"
        MinWidth="750" MinHeight="500"
        Background="{StaticResource BgPrimaryBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Step progress bar -->
        <Border Grid.Row="0" Background="{StaticResource BgSecondaryBrush}" Padding="16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ProgressBar x:Name="StepProgress" Height="8" Foreground="{StaticResource AccentBrush}" Background="{StaticResource BgTertiaryBrush}" BorderThickness="0" Minimum="0" Value="0" Maximum="5" />
                <TextBlock Grid.Column="1" x:Name="StepIndicator" Text="{StaticResource Step} 1/6" Foreground="{StaticResource TextSecondaryBrush}" Margin="12,0,0,0" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Main content area -->
        <Border Grid.Row="1" Background="{StaticResource BgPrimaryBrush}">
            <Grid x:Name="ContentArea" Margin="40,24">
                <!-- Content swapped in code-behind by step -->
                <TextBlock x:Name="EmptyStep" Text="Cargando..." Foreground="{StaticResource TextMutedBrush}"/>
            </Grid>
        </Border>

        <!-- Navigation buttons -->
        <Border Grid.Row="2" Background="{StaticResource BgSecondaryBrush}" Padding="16,8">
            <StackPanel x:Name="NavPanel" Orientation="Horizontal" FlowDirection="RightToLeft">
                <Button x:Name="NextBtn" Content="{StaticResource Next}" Style="{StaticResource PrimaryButton}" Click="NextStep" IsEnabled="False"/>
                <Button x:Name="BackBtn" Content="{StaticResource Back}" Style="{StaticResource SecondaryButton}" Click="PrevStep" IsEnabled="False" Margin="0,0,8,0" Visibility="Visible"/>
                <Button x:Name="CancelBtn" Content="{StaticResource Cancel}" Style="{StaticResource SecondaryButton}" Click="CancelWizard" Margin="0,0,8,0" Visibility="Visible"/>
            </StackPanel>
        </Border>

        <!-- Status bar -->
        <Border Grid.Row="3" Background="{StaticResource BgTertiaryBrush}" Padding="8,4">
            <TextBlock x:Name="StatusBar" Text="Listo" Foreground="{StaticResource TextMutedBrush}" FontSize="11"/>
        </Border>
    </Grid>
</Window>

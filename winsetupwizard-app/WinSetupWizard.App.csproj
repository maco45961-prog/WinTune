<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <AssemblyName>WinSetupWizard</AssemblyName>
    <RootNamespace>WinSetupWizard</RootNamespace>
    <Version>1.0.0</Version>
    <Authors>WinOptimizer Contributors</Authors>
    <Description>Fresh Windows setup wizard for the WinOptimizer ecosystem</Description>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="System.Management" Version="8.0.0" />
  </ItemGroup>

</Project>
